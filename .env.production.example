# Kopiér denne fil til .env og udfyld værdierne
# Bruges af docker-compose.yml

# Generer sikre nøgler med:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_SECRET=skift_mig_til_en_sikker_random_streng
ENCRYPTION_KEY=skift_mig_til_en_sikker_random_streng

# URL som familie-medlemmer tilgår appen via (Tailscale IP eller hostname)
CLIENT_URL=http://100.x.x.x

# Valgfrit — bruges til password-reset emails
RESEND_API_KEY=
RESEND_ALLOWED_EMAIL=

# Bruges KUN til første opstart (admin-bruger oprettes via init-kommando)
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=skift_mig_til_en_sikker_adgangskode
INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_DISPLAY_NAME=Admin
