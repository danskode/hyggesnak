# JWT Secret Key
# An idea: Generate in terminal with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_min_32_characters

# JWT Token Expiry Time (in minutes)
JWT_EXPIRY_MINUTES=1440

# Resend API Key for sending emails
RESEND_API_KEY=re_your_api_key_here

# Allowed email for Resend
RESEND_ALLOWED_EMAIL=din@email.com

# Client URL for CORS configuration
CLIENT_URL=http://localhost:5173

# Server Port
# PORT=8081

# Encryption Key for message content (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# GIF-leverandør — vælg 'giphy' (gratis) eller 'heypster' (europæisk, GDPR)
GIF_PROVIDER=giphy

# Giphy API key (gratis developer tier: 100 req/time)
# Opret gratis nøgle på: https://developers.giphy.com
GIPHY_API_KEY=your_giphy_api_key_here

# Heypster API key (europæisk, GDPR/DSA-compliant)
# Kræver betalt abonnement: https://heypster.com
# HEYPSTER_API_KEY=your_heypster_api_key_here